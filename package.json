{
  "name": "@void-ai/sdk",
  "version": "0.1.0",
  "description": "Semantic instrumentation for AI agents built on OpenTelemetry",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
